{
  "info": {
    "name": "API коротких ссылок",
    "description": "API для управления короткими ссылками",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Авторизация",
      "item": [
        {
          "name": "Регистрация пользователя",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"Password123!\",\n    \"password_confirmation\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Вход в систему",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.token) {",
                  "        pm.environment.set('auth_token', response.data.token);",
                  "        pm.environment.set('user_id', response.data.user.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Получить текущего пользователя",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Обновить токен",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "refresh"]
            }
          },
          "response": []
        },
        {
          "name": "Выход из системы",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "logout"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Управление ссылками",
      "item": [
        {
          "name": "Получить все ссылки",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/links?page=1&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "links"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "15"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Создать ссылку",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.id) {",
                  "        pm.environment.set('link_id', response.data.id);",
                  "        pm.environment.set('link_sref', response.data.sref);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"href\": \"https://example.com/very-long-url-{{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/links",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "links"]
            }
          },
          "response": []
        },
        {
          "name": "Получить одну ссылку",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/links/{{link_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "links", "{{link_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Обновить ссылку",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"href\": \"https://updated-example.com/new-url-{{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/links/{{link_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "links", "{{link_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Удалить ссылку",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/links/{{link_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "links", "{{link_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Получить статистику",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/links/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "links", "stats"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Публичные маршруты",
      "item": [
        {
          "name": "Перейти по короткой ссылке",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/html"
              }
            ],
            "url": {
              "raw": "{{base_url}}/l/{{link_sref}}",
              "host": ["{{base_url}}"],
              "path": ["l", "{{link_sref}}"]
            }
          },
          "response": []
        },
        {
          "name": "Проверить короткую ссылку (JSON)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/l/{{link_sref}}",
              "host": ["{{base_url}}"],
              "path": ["l", "{{link_sref}}"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "link_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "link_sref",
      "value": "",
      "type": "string"
    }
  ]
}